{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18800,
    "auth": {
      "mode": "token",
      "token": "nat-test-relay-token-please-change-in-real-deployments"
    }
  },
  "plugins": {
    "entries": {
      "libp2p-mesh": {
        "enabled": true,
        "config": {
          "discovery": "bootstrap",
          "bootstrapList": [],
          "listenAddrs": ["/ip4/0.0.0.0/tcp/4001"],
          "announceAddrs": ["/dns4/relay/tcp/4001"],
          "enableCircuitRelayServer": true,
          "enableUPnP": false,
          "enableAutoNAT": false,
          "instanceName": "nat-test-relay"
        }
      }
    }
  },
  "channels": {
    "libp2p-mesh": { "enabled": true }
  }
}
