{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18800,
    "auth": {
      "mode": "token",
      "token": "nat-test-client-b-token-please-change-in-real-deployments"
    }
  },
  "plugins": {
    "entries": {
      "libp2p-mesh": {
        "enabled": true,
        "config": {
          "discovery": "bootstrap",
          "bootstrapList": ["/dns4/relay/tcp/4001/p2p/__RELAY_PEER_ID__"],
          "relayList":     ["/dns4/relay/tcp/4001/p2p/__RELAY_PEER_ID__"],
          "enableUPnP": false,
          "instanceName": "nat-test-client-b",
          "inboundChannel": "feishu",
          "inboundTarget": "user:client-b",
          "deliveryAckTimeoutMs": 15000
        }
      }
    }
  },
  "channels": {
    "libp2p-mesh": { "enabled": true }
  }
}
