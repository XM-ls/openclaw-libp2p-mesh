{
  "name": "@openclaw/libp2p-mesh",
  "version": "2026.5.8",
  "description": "OpenClaw libp2p P2P mesh network plugin for cross-instance agent communication",
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "api.ts",
    "src",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@libp2p/bootstrap": "^10.1.5",
    "@libp2p/mdns": "^9.0.14",
    "@libp2p/mplex": "^9.0.12",
    "@libp2p/noise": "^12.0.1",
    "@libp2p/peer-id-factory": "^3.0.11",
    "@libp2p/tcp": "^8.0.13",
    "@libp2p/websockets": "^8.2.0",
    "@multiformats/multiaddr": "^12.5.1",
    "it-length-prefixed": "^10.0.1",
    "it-pipe": "^3.0.1",
    "libp2p": "^0.46.16",
    "uint8arraylist": "^2.4.8"
  },
  "devDependencies": {
    "openclaw": "^2026.5.7",
    "tsx": "^4.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "libp2p-mesh",
      "label": "P2P Mesh",
      "selectionLabel": "P2P Mesh",
      "detailLabel": "P2P Mesh",
      "docsPath": "/channels/libp2p-mesh",
      "docsLabel": "libp2p-mesh",
      "blurb": "libp2p mesh network for cross-instance agent communication.",
      "systemImage": "network"
    },
    "install": {
      "npmSpec": "@openclaw/libp2p-mesh",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.24"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToNpm": true
    }
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "libp2p",
    "p2p",
    "mesh",
    "decentralized"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USERNAME/openclaw-libp2p-mesh.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/openclaw-libp2p-mesh/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/openclaw-libp2p-mesh#readme"
}
